   x1 = rnorm(n), x2 = rnorm(n), x3 = rnorm(n)
 )

 #fit a linear model per response (named by response)
 mods <- list(
   y1 = lm(y1 ~ x1 + x2 + x3, data = dat),
   y2 = lm(y2 ~ x1 + x2 + x3, data = dat)
 )

 #apparent + leave-one-out cross-validated fit statistics
